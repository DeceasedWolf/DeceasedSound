<Window x:Class="SoundboardMixer.App.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d"
        Title="DeceasedSound"
        Width="1360"
        Height="820"
        MinWidth="1120"
        MinHeight="700"
        Background="{StaticResource Brush.Base}"
        Foreground="{StaticResource Brush.Text}">
    <Grid Margin="24"
          Background="{StaticResource Brush.Base}">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <Grid Grid.Row="0"
              Margin="0,0,0,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*" />
                <ColumnDefinition Width="Auto" />
            </Grid.ColumnDefinitions>

            <TextBlock VerticalAlignment="Center"
                       Style="{StaticResource PageTitleTextStyle}"
                       Text="DeceasedSound" />

            <StackPanel Grid.Column="1"
                        HorizontalAlignment="Right"
                        VerticalAlignment="Center"
                        Orientation="Horizontal">
                <Button Margin="0,0,8,0"
                        Content="Refresh Devices"
                        Command="{Binding RefreshDevicesCommand}" />

                <Button Margin="0,0,8,0"
                        Content="Restart Audio"
                        Command="{Binding RestartAudioCommand}" />

                <Button Content="Settings"
                        Command="{Binding OpenSettingsCommand}" />
            </StackPanel>
        </Grid>

        <Border Grid.Row="1"
                Margin="0,0,0,14"
                Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Margin="0,0,0,14"
                           Style="{StaticResource SectionTitleTextStyle}"
                           Text="Devices" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0,0,18,0">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Microphone Input" />
                        <ComboBox MinWidth="260"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding MicrophoneDevices}"
                                  SelectedItem="{Binding SelectedMicrophone}" />
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="0,0,18,0">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Mixed Output" />
                        <ComboBox MinWidth="260"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding OutputDevices}"
                                  SelectedItem="{Binding SelectedOutput}" />
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Speaker Monitor" />
                        <ComboBox MinWidth="260"
                                  DisplayMemberPath="DisplayName"
                                  ItemsSource="{Binding OutputDevices}"
                                  SelectedItem="{Binding SelectedSpeakerOutput}" />
                        <CheckBox Margin="0,10,0,0"
                                  Content="Hear clips in speaker monitor"
                                  IsChecked="{Binding IsSpeakerMonitorEnabled}" />
                    </StackPanel>
                </Grid>

                <StackPanel Grid.Row="2"
                            Margin="0,14,0,0"
                            VerticalAlignment="Center"
                            Orientation="Horizontal">
                    <TextBlock Margin="0,0,8,0"
                               VerticalAlignment="Center"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource Brush.Subtext0}"
                               Text="Engine" />
                    <TextBlock VerticalAlignment="Center"
                               Foreground="{StaticResource Brush.Blue}"
                               Text="{Binding EngineStatus}" />
                </StackPanel>
            </Grid>
        </Border>

        <Border Grid.Row="2"
                Margin="0,0,0,14"
                Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                </Grid.RowDefinitions>

                <TextBlock Margin="0,0,0,14"
                           Style="{StaticResource SectionTitleTextStyle}"
                           Text="Mixer" />

                <Grid Grid.Row="1">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0"
                                Margin="0,0,24,0">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Microphone Volume" />
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Right"
                                       Width="56"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.Subtext1}"
                                       Text="{Binding MicrophoneVolumePercent, StringFormat={}{0:F0}%}"
                                       TextAlignment="Right" />
                            <Slider Minimum="0"
                                    Maximum="300"
                                    Value="{Binding MicrophoneVolumePercent}" />
                        </DockPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1"
                                Margin="0,0,24,0">
                        <TextBlock Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Soundboard Volume" />
                        <DockPanel LastChildFill="True">
                            <TextBlock DockPanel.Dock="Right"
                                       Width="56"
                                       Margin="10,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.Subtext1}"
                                       Text="{Binding SoundboardVolumePercent, StringFormat={}{0:F0}%}"
                                       TextAlignment="Right" />
                            <Slider Minimum="0"
                                    Maximum="100"
                                    Value="{Binding SoundboardVolumePercent}" />
                        </DockPanel>
                    </StackPanel>

                    <CheckBox Grid.Column="2"
                              Margin="0,22,18,0"
                              VerticalAlignment="Center"
                              Content="Mute Microphone"
                              IsChecked="{Binding IsMicrophoneMuted}" />

                    <Button Grid.Column="3"
                            Margin="0,16,0,0"
                            VerticalAlignment="Center"
                            Command="{Binding StopAllCommand}"
                            Content="Stop All"
                            Style="{StaticResource DangerButtonStyle}" />
                </Grid>
            </Grid>
        </Border>

        <Border Grid.Row="3"
                Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,12"
                           LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               Style="{StaticResource SectionTitleTextStyle}"
                               Text="Clips" />

                    <StackPanel DockPanel.Dock="Right"
                                Orientation="Horizontal">
                        <Button Margin="0,0,8,0"
                                Command="{Binding AddClipsCommand}"
                                Content="Add Clips"
                                Style="{StaticResource AccentButtonStyle}" />
                        <Button Margin="0,0,8,0"
                                Command="{Binding OpenClipBrowserCommand}"
                                Content="Dashboard" />
                        <Button Margin="0,0,8,0"
                                Command="{Binding PlaySelectedClipCommand}"
                                Content="Play Selected" />
                        <Button Command="{Binding RemoveSelectedClipCommand}"
                                Content="Remove Selected" />
                    </StackPanel>
                </DockPanel>

                <DataGrid Grid.Row="1"
                          AlternationCount="2"
                          AutoGenerateColumns="False"
                          CanUserAddRows="False"
                          CanUserDeleteRows="False"
                          CanUserResizeColumns="False"
                          HeadersVisibility="Column"
                          IsReadOnly="False"
                          ItemsSource="{Binding Clips}"
                          SelectedItem="{Binding SelectedClip}"
                          SelectionMode="Single">
                    <DataGrid.RowStyle>
                        <Style TargetType="{x:Type DataGridRow}">
                            <Setter Property="Background"
                                    Value="{StaticResource Brush.Mantle}" />
                            <Setter Property="Foreground"
                                    Value="{StaticResource Brush.Text}" />
                            <Setter Property="SnapsToDevicePixels"
                                    Value="True" />
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="{StaticResource Brush.Surface0}" />
                                </Trigger>
                                <Trigger Property="IsSelected"
                                         Value="True">
                                    <Setter Property="Background"
                                            Value="{StaticResource Brush.Selection}" />
                                    <Setter Property="Foreground"
                                            Value="{StaticResource Brush.Rosewater}" />
                                </Trigger>
                                <DataTrigger Binding="{Binding IsAvailable}"
                                             Value="False">
                                    <Setter Property="Background"
                                            Value="#26F38BA8" />
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </DataGrid.RowStyle>
                    <DataGrid.Columns>
                        <DataGridTextColumn Header="Label"
                                            Binding="{Binding DisplayName, UpdateSourceTrigger=LostFocus}"
                                            ElementStyle="{StaticResource DataGridTextElementStyle}"
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"
                                            Width="170" />
                        <DataGridTextColumn Header="Source File"
                                            Binding="{Binding SourcePath}"
                                            ElementStyle="{StaticResource DataGridTextElementStyle}"
                                            IsReadOnly="True"
                                            Width="*" />
                        <DataGridTextColumn Header="File Status"
                                            Binding="{Binding AvailabilityText}"
                                            ElementStyle="{StaticResource DataGridTextElementStyle}"
                                            IsReadOnly="True"
                                            Width="140" />
                        <DataGridTemplateColumn Header="Clip Volume"
                                                Width="170">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <DockPanel Margin="10,0"
                                               LastChildFill="True">
                                        <TextBlock DockPanel.Dock="Right"
                                                   Width="48"
                                                   Margin="8,0,0,0"
                                                   VerticalAlignment="Center"
                                                   Foreground="{StaticResource Brush.Subtext1}"
                                                   Text="{Binding VolumePercent, StringFormat={}{0:F0}%}"
                                                   TextAlignment="Right" />
                                        <Slider Minimum="0"
                                                Maximum="100"
                                                TickFrequency="5"
                                                Value="{Binding VolumePercent, UpdateSourceTrigger=PropertyChanged}" />
                                    </DockPanel>
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTextColumn Header="Hotkey"
                                            Binding="{Binding HotkeyText, UpdateSourceTrigger=LostFocus}"
                                            ElementStyle="{StaticResource DataGridTextElementStyle}"
                                            EditingElementStyle="{StaticResource DataGridEditingTextBoxStyle}"
                                            Width="120" />
                        <DataGridTextColumn Header="Hotkey Status"
                                            Binding="{Binding HotkeyStatus}"
                                            ElementStyle="{StaticResource DataGridTextElementStyle}"
                                            IsReadOnly="True"
                                            Width="150" />
                        <DataGridTemplateColumn Header=""
                                                Width="70">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.PlayClipCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Content="Play"
                                            Style="{StaticResource DataGridActionButtonStyle}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                        <DataGridTemplateColumn Header=""
                                                Width="85">
                            <DataGridTemplateColumn.CellTemplate>
                                <DataTemplate>
                                    <Button Command="{Binding DataContext.RemoveClipCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                            CommandParameter="{Binding}"
                                            Content="Remove"
                                            Style="{StaticResource DataGridActionButtonStyle}" />
                                </DataTemplate>
                            </DataGridTemplateColumn.CellTemplate>
                        </DataGridTemplateColumn>
                    </DataGrid.Columns>
                </DataGrid>
            </Grid>
        </Border>

        <Border Grid.Row="4"
                Margin="0,14,0,0"
                Style="{StaticResource PanelBorderStyle}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <ToggleButton x:Name="LogToggle"
                              Margin="0,0,0,12"
                              HorizontalAlignment="Left"
                              Content="Logs"
                              IsChecked="False"
                              Style="{StaticResource SectionToggleButtonStyle}" />

                <ListBox Grid.Row="1"
                         Height="110"
                         BorderThickness="0"
                         FontFamily="Consolas"
                         HorizontalContentAlignment="Stretch"
                         ItemsSource="{Binding LogEntries}"
                         ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                         ScrollViewer.VerticalScrollBarVisibility="Hidden"
                         Visibility="{Binding IsChecked, ElementName=LogToggle, Converter={StaticResource BooleanToVisibilityConverter}}">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <TextBlock Foreground="{StaticResource Brush.Subtext1}"
                                       Text="{Binding DisplayText}"
                                       TextWrapping="Wrap" />
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.RowSpan="4"
                Panel.ZIndex="20"
                Style="{StaticResource PanelBorderStyle}"
                Visibility="{Binding IsClipBrowserOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,14"
                           LastChildFill="False">
                    <StackPanel DockPanel.Dock="Left">
                        <TextBlock Style="{StaticResource PageTitleTextStyle}"
                                   Text="Sound Browser" />
                        <TextBlock Margin="0,4,0,0"
                                   Foreground="{StaticResource Brush.Subtext1}"
                                   Text="{Binding Clips.Count, StringFormat={}{0} sounds loaded}" />
                    </StackPanel>

                    <StackPanel DockPanel.Dock="Right"
                                VerticalAlignment="Top"
                                Orientation="Horizontal">
                        <Button Margin="0,0,8,0"
                                Command="{Binding AddClipsCommand}"
                                Content="Add Clips"
                                Style="{StaticResource AccentButtonStyle}" />
                        <Button Margin="0,0,8,0"
                                Command="{Binding StopAllCommand}"
                                Content="Stop All"
                                Style="{StaticResource DangerButtonStyle}" />
                        <Button Command="{Binding CloseClipBrowserCommand}"
                                Content="Close" />
                    </StackPanel>
                </DockPanel>

                <Grid Grid.Row="1"
                      Margin="0,0,0,16">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Margin="0,0,10,0"
                                   VerticalAlignment="Center"
                                   Style="{StaticResource FieldLabelTextStyle}"
                                   Text="Find Sound" />
                        <TextBox Style="{StaticResource ClipBrowserSearchBoxStyle}"
                                 Text="{Binding ClipBrowserSearchText, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                </Grid>

                <ScrollViewer Grid.Row="2"
                              HorizontalScrollBarVisibility="Disabled"
                              VerticalScrollBarVisibility="Auto">
                    <ItemsControl ItemsSource="{Binding ClipBrowserClips}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <WrapPanel />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Button Command="{Binding DataContext.ToggleClipPlaybackCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                        CommandParameter="{Binding}"
                                        Style="{StaticResource SoundTileButtonStyle}"
                                        ToolTip="{Binding SourcePath}">
                                    <Grid>
                                        <Grid.RowDefinitions>
                                            <RowDefinition Height="*" />
                                            <RowDefinition Height="Auto" />
                                        </Grid.RowDefinitions>

                                        <TextBlock Style="{StaticResource SoundTileTitleTextStyle}"
                                                   Text="{Binding DisplayName}" />

                                        <DockPanel Grid.Row="1"
                                                   LastChildFill="True">
                                            <TextBlock DockPanel.Dock="Right"
                                                       Margin="8,0,0,0"
                                                       Foreground="{StaticResource Brush.Subtext0}"
                                                       Text="{Binding VolumePercent, StringFormat={}{0:F0}%}" />
                                            <TextBlock Style="{StaticResource SoundTileStatusTextStyle}"
                                                       Text="{Binding AvailabilityText}" />
                                        </DockPanel>
                                    </Grid>
                                </Button>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>
            </Grid>
        </Border>

        <Border Grid.Row="1"
                Grid.RowSpan="4"
                Panel.ZIndex="30"
                Style="{StaticResource PanelBorderStyle}"
                Visibility="{Binding IsSettingsOpen, Converter={StaticResource BooleanToVisibilityConverter}}">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto" />
                    <RowDefinition Height="*" />
                </Grid.RowDefinitions>

                <DockPanel Margin="0,0,0,18"
                           LastChildFill="False">
                    <TextBlock DockPanel.Dock="Left"
                               VerticalAlignment="Center"
                               Style="{StaticResource PageTitleTextStyle}"
                               Text="Settings" />

                    <Button DockPanel.Dock="Right"
                            Command="{Binding CloseSettingsCommand}"
                            Content="Close" />
                </DockPanel>

                <StackPanel Grid.Row="1">
                    <Border Padding="0,0,0,16"
                            BorderBrush="{StaticResource Brush.Surface0}"
                            BorderThickness="0,0,0,1">
                        <CheckBox Content="Auto Start on Windows Start"
                                  IsChecked="{Binding IsAutoStartOnWindowsStart}" />
                    </Border>

                    <Border Padding="0,16,0,16"
                            BorderBrush="{StaticResource Brush.Surface0}"
                            BorderThickness="0,0,0,1">
                        <CheckBox Content="Minimize to System Tray when clicking X"
                                  IsChecked="{Binding IsMinimizeToSystemTrayOnClose}" />
                    </Border>

                    <Border Padding="0,16,0,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="220" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       VerticalAlignment="Center"
                                       Style="{StaticResource FieldLabelTextStyle}"
                                       Text="Stop All Shortcut" />

                            <TextBox Grid.Column="1"
                                     Text="{Binding StopAllHotkeyText, UpdateSourceTrigger=LostFocus, TargetNullValue=''}" />

                            <TextBlock Grid.Column="2"
                                       Margin="12,0,0,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource Brush.Subtext0}"
                                       Text="{Binding StopAllHotkeyStatus}" />
                        </Grid>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>
    </Grid>
</Window>
